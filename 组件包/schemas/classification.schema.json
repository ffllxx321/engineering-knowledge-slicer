{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engineering-knowledge-slicer://schema/classification-1.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "library", "folder_type", "document_type", "model_confidence", "reason", "evidence", "alternatives"],
  "properties": {
    "schema_version": { "const": "1.1" },
    "library": { "enum": ["bid", "business"] },
    "folder_type": { "type": "string", "minLength": 1 },
    "document_type": { "type": "string", "minLength": 1 },
    "model_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "alternatives": { "type": "array", "maxItems": 2, "items": { "type": "object", "required": ["folder_type", "model_confidence", "reason"], "properties": { "folder_type": { "type": "string" }, "model_confidence": { "type": "number", "minimum": 0, "maximum": 1 }, "reason": { "type": "string" } } } }
  }
}
