{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engineering-knowledge-slicer://schema/card-1.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "card_id", "atom_fingerprint", "card_kind", "library", "folder_type", "output_folder", "status", "source_file", "source_link", "source_hash", "parent_summary", "related", "tags", "confidence", "confidence_components", "schema_version", "pipeline_version", "prompt_bundle_version"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "card_id": { "type": "string", "minLength": 1 },
    "atom_fingerprint": { "type": "string", "minLength": 1 },
    "card_kind": { "enum": ["static", "event"] },
    "Info_Type": { "type": "string" },
    "Event_Type": { "type": "string" },
    "library": { "enum": ["bid", "business"] },
    "folder_type": { "type": "string" },
    "output_folder": { "type": "string" },
    "project": { "type": "string" },
    "client": { "type": "string" },
    "stage": { "type": "string" },
    "status": { "enum": ["draft", "confirmed", "superseded"] },
    "Category": { "type": "string" },
    "TagL1": { "type": "string" },
    "TagL2": { "type": "string" },
    "source_file": { "type": "string" },
    "source_link": { "type": "string" },
    "source_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_page": { "type": "string" },
    "source_locator": { "type": "string" },
    "evidence_quote": { "type": "string" },
    "parent_summary": { "type": "string" },
    "supersedes": { "type": "string" },
    "superseded_by": { "type": "string" },
    "related": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "relations": { "type": "array", "items": { "type": "object" } },
    "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_components": {
      "type": "object",
      "required": ["P", "T", "E", "S", "A"],
      "properties": {
        "P": { "type": "number", "minimum": 0, "maximum": 1 },
        "T": { "type": "number", "minimum": 0, "maximum": 1 },
        "E": { "type": "number", "minimum": 0, "maximum": 1 },
        "S": { "type": "number", "minimum": 0, "maximum": 1 },
        "A": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "created": { "type": "string" },
    "updated": { "type": "string" },
    "content": { "type": "object" },
    "schema_version": { "const": "1.1" },
    "pipeline_version": { "type": "string" },
    "prompt_bundle_version": { "type": "string" }
  }
}
