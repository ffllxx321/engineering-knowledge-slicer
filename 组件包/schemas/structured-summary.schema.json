{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engineering-knowledge-slicer://schema/structured-summary-1.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["document_title", "library", "folder_type", "document_type", "executive_summary", "key_points", "evidence", "coverage", "schema_version"],
  "properties": {
    "document_title": { "type": "string", "minLength": 1 },
    "library": { "enum": ["bid", "business"] },
    "folder_type": { "type": "string", "minLength": 1 },
    "document_type": { "type": "string", "minLength": 1 },
    "executive_summary": { "type": "string" },
    "entities": { "type": "array", "items": { "type": "object" } },
    "key_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["point_id", "kind", "content", "evidence_ids"],
        "properties": {
          "point_id": { "type": "string" },
          "kind": { "type": "string" },
          "content": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "locator", "quote"],
        "properties": {
          "evidence_id": { "type": "string" },
          "locator": { "type": "string" },
          "quote": { "type": "string" }
        }
      }
    },
    "suggested_links": { "type": "array", "items": { "type": "object" } },
    "coverage": {
      "type": "object",
      "required": ["chunk_ids", "complete"],
      "properties": {
        "chunk_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "complete": { "type": "boolean" }
      }
    },
    "model_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "schema_version": { "const": "1.1" }
  }
}
